# Chezmoi source files that should never be applied to $HOME.
/.chezmoi.toml.tmpl
/.chezmoidata/
/.chezmoiignore.tmpl
/.chezmoiscripts/

# Compiled into ~/.dotfiles/compiled/shell at apply time (source-only modules).
.dotfiles/common/aliases
.dotfiles/common/functions
.dotfiles/laptop/
.dotfiles/container/
.dotfiles/local/
.dotfiles/remote/
.dotfiles/fragments/
.config/dotfiles/role-aliases

# GUI-conditional target paths (gated on .gui, not .role).
{{- if not .gui }}
.local/bin/gui/
.config/autostart/
.config/mimeapps.list
.local/share/applications/deb-dpkg-install.desktop
.desktop/
Desktop/
Templates/
{{- end }}

# Backups config — server and laptop only (restic/resticprofile).
{{- if not (or (eq .role "server") (eq .role "laptop")) }}
.config/backups/
{{- end }}

# Git directory placeholders.
.gitkeep

# macOS / editor metadata that might accidentally appear in the source tree.
.DS_Store
