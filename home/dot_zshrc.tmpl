# ~/.zshrc: executed by zsh for interactive shells.

DF_DIR="${HOME}/.dotfiles"

# Load shell modules from bootstrap data.
{{ template "source-bootstrap.tmpl" dict "bootstrap" .bootstrap "role" .role "shell" "zsh" }}

# Load optional fragments based on configuration.
{{ template "load-fragments.tmpl" . }}

# Role-specific aliases generated by chezmoi.
[ -r "${HOME}/.config/dotfiles/role-aliases" ] && . "${HOME}/.config/dotfiles/role-aliases"

# Host-specific bootstrap (untracked).
[ -r "${HOME}/.config/dotfiles/host-bootstrap" ] && . "${HOME}/.config/dotfiles/host-bootstrap"

# Machine-local, untracked overrides.
[ -r ~/.zshrc.local ] && . ~/.zshrc.local

# Build PATH from chezmoi data.
{{ template "setup-path.tmpl" dict "paths" .paths }}

# Late shell integrations — must be at the very end.
# Tools like zoxide that wrap `cd` need to be initialized last so nothing
# sourced after them overrides their modifications.
{{ template "source-late-init.tmpl" dict "bootstrap" .bootstrap "shell" "zsh" }}
