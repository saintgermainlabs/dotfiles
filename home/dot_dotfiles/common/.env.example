# Copy to ~/.dotfiles/bash/.env and fill in real values.
# This file is safe to commit; ~/.dotfiles/bash/.env is gitignored.

export ANTHROPIC_API_KEY=""

export REMOTE_USER=""
export REMOTE_HOST=""
export REMOTE_PORT="22"
export REMOTE_SSH_KEY="$HOME/.ssh/id_ed25519_server"
export SERVER_NAME=""
export SERVER_IP=""

# Private SSH servers (fill in locally; never commit real IPs or keys).
export SSH_HETZNER_IP=""
export SSH_HETZNER_USER="root"
export SSH_HETZNER_KEY="~/.ssh/id_ed25519_server"
