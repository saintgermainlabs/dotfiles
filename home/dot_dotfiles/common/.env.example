# Copy to ~/.dotfiles/dot_env/.env and fill in real values.
# This file is safe to commit; ~/.dotfiles/dot_env/.env is gitignored.

# ── 1Password CLI ─────────────────────────────────────────────────────
# For dev containers / CI / headless servers, use a Service Account token.
# Create one at: https://developer.1password.com/docs/service-accounts/
# On laptops with the 1Password desktop app, leave this empty — the CLI
# will use app integration (biometric) automatically.
export OP_SERVICE_ACCOUNT_TOKEN=""

# ── API keys ──────────────────────────────────────────────────────────
export ANTHROPIC_API_KEY=""

export REMOTE_USER=""
export REMOTE_HOST=""
export REMOTE_PORT="22"
export REMOTE_SSH_KEY="$HOME/.ssh/id_ed25519_server"
export SERVER_NAME=""
export SERVER_IP=""

# Private SSH servers (fill in locally; never commit real IPs or keys).
export SSH_HETZNER_IP=""
export SSH_HETZNER_USER="root"
export SSH_HETZNER_KEY="~/.ssh/id_ed25519_server"
