# Remote Coolify management helpers
# Requires: coolify CLI, tailscale, and a configured coolify context.

# ── Coolify context helpers ──────────────────────────────────────────

# List available Coolify contexts (configured instances)
coolify_contexts() {
  if ! command -v coolify &>/dev/null; then
    echo "coolify: command not found" >&2
    return 1
  fi
  coolify context list 2>/dev/null || echo "No contexts configured" >&2
}

# Quick-select a Coolify context by partial name
coolify_use() {
  local name="$1"
  [ -z "$name" ] && { echo "Usage: coolify_use <context_name>" >&2; return 1; }
  coolify context set-default "$name" 2>/dev/null
}

# ── Server discovery (via Tailscale) ─────────────────────────────────

# List Tailscale machines tagged for Coolify (via tailscale tags)
coolify_hosts() {
  if ! command -v tailscale &>/dev/null; then
    echo "tailscale: command not found" >&2
    return 1
  fi
  tailscale status --json 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
peers = data.get('Peer', {})
results = []
if 'Self' in data:
    s = data['Self']
    tags = s.get('Tags', [])
    if any('coolify' in t.lower() for t in tags):
        results.append((s.get('DNSName', '').rstrip('.'), s.get('TailscaleIPs', [''])[0], 'self'))
for pid, peer in peers.items():
    tags = peer.get('Tags', [])
    if any('coolify' in t.lower() for t in tags):
        results.append((peer.get('DNSName', '').rstrip('.'), peer.get('TailscaleIPs', [''])[0], 'peer'))
for name, ip, kind in sorted(results):
    print(f'{name:40s} {ip:15s} ({kind})')
" 2>/dev/null || tailscale status | grep -i coolify
}

