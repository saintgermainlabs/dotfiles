# ── SSH shortcut via Tailscale ───────────────────────────────────────

# SSH into a Coolify host using its Tailscale MagicDNS name
# Usage: coolify_ssh <hostname> [user]
coolify_ssh() {
  local host="$1"
  local user="${2:-root}"
  [ -z "$host" ] && { echo "Usage: coolify_ssh <hostname> [user]" >&2; return 1; }
  # Resolve via tailscale if not a FQDN
  if ! [[ "$host" == *.* ]]; then
    local resolved
    resolved=$(tailscale status --json 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
for pid, peer in data.get('Peer', {}).items():
    name = peer.get('DNSName', '').rstrip('.')
    tag = name.split('.')[0]
    if tag == '$host' or name.startswith('$host.'):
        print(name)
        break
" 2>/dev/null)
    [ -n "$resolved" ] && host="$resolved"
  fi
  ssh "${user}@${host}"
}

# ── Resource search (via API) ────────────────────────────────────────

# Search for resources by Project/resource-name glob pattern.
# Returns project UUID, env UUID, type, and resource UUID/name.
# Usage: coolify_search <ProjectName/glob-pattern>
coolify_search() {
  local pattern="$1"
  [ -z "$pattern" ] && { echo "Usage: coolify_search <ProjectName/glob-pattern>" >&2; return 1; }

  local project_part="${pattern%%/*}"
  local resource_part="${pattern#*/}"
  [ "$project_part" = "$pattern" ] && { echo "Pattern must include / (e.g. ProjectName/app-name*)" >&2; return 1; }

  local config="$HOME/.config/coolify/config.json"
  [ ! -f "$config" ] && { echo "Coolify config not found" >&2; return 1; }

  python3 -c "
import json, os, urllib.request, fnmatch, ssl

CONFIG = os.path.expanduser('$config')
PROJECT_PAT = '$project_part'
RESOURCE_PAT = '$resource_part'

with open(CONFIG) as f:
    cfg = json.load(f)

inst = next((i for i in cfg['instances'] if i.get('default')), None)
if not inst:
    exit(1)

fqdn = inst['fqdn'].rstrip('/')
token = inst['token']
ssl_ctx = ssl.create_default_context()
ssl_ctx.check_hostname = False
ssl_ctx.verify_mode = ssl.CERT_NONE

def api(path):
    headers = {'Authorization': f'Bearer {token}', 'User-Agent': 'curl/7.88.1'}
    req = urllib.request.Request(f'{fqdn}/api/v1/{path}', headers=headers)
    with urllib.request.urlopen(req, context=ssl_ctx) as r:
        return json.loads(r.read())

projects = api('projects')
found = 0
for proj in projects:
    if not fnmatch.fnmatch(proj['name'], PROJECT_PAT):
        continue
    proj_detail = api(f'projects/{proj[\"uuid\"]}')
    for env in proj_detail.get('environments', []):
        env_uuid = env['uuid']
        resources = api(f'projects/{proj[\"uuid\"]}/{env_uuid}')
        for key in ('applications', 'services', 'postgresqls', 'mysqls', 'mongodbs', 'mariadbs', 'redis'):
            for r in resources.get(key, []):
                if fnmatch.fnmatch(r['name'], RESOURCE_PAT):
                    t = key.rstrip('s')
                    if t == 'postgresql':
                        t = 'postgresql'
                    print(f'project={proj[\"uuid\"]} name={proj[\"name\"]} env={env_uuid} env_name={env[\"name\"]} type={t} uuid={r[\"uuid\"]} resource={r[\"name\"]}')
                    found += 1
if not found:
    exit(1)
" 2>/dev/null || { echo "No resources matching \"$pattern\"" >&2; return 1; }
}

