}

# Copy EXIF date from one file to another (requires exiftool)
# Usage: copy_date <source_file> <target_file>
copy_date() {
  if ! command -v exiftool &>/dev/null; then
    echo "exiftool: command not found (install with: sudo apt install libimage-exiftool-perl)" >&2
    return 1
  fi

  if [ $# -ne 2 ]; then
    echo "Usage: copy_date <source_file> <target_file>" >&2
    return 1
  fi

  exiftool -TagsFromFile "$1" -AllDates "$2"
}

# Batch rename with a numbered pattern
# Usage: batch_rename <pattern> <files...>
# Example: batch_rename "vacation_%03d" *.jpg -> vacation_001.jpg, vacation_002.jpg...
batch_rename() {
  if [ $# -lt 2 ]; then
    echo "Usage: batch_rename <pattern> <files...>" >&2
    echo "Example: batch_rename \"vacation_%%03d\" *.jpg" >&2
    return 1
  fi

  local pattern="$1"
  shift

  local ext name counter=1
  for file in "$@"; do
    if [ -f "$file" ]; then
      ext="${file##*.}"
      name=$(printf "$pattern" "$counter")
      if [ -n "$ext" ] && [ "$ext" != "$file" ]; then
        name="${name}.${ext}"
      fi
      if [ ! -e "$name" ]; then
        mv -n "$file" "$name"
      else
        echo "Skipping: $name already exists" >&2
      fi
      ((counter++))
    fi
  done
}

# Convert HEIC/HEIF images to JPEG (requires libheif-examples)
# Usage: heic2jpg <files...>
heic2jpg() {
  if ! command -v heif-convert &>/dev/null; then
    echo "heif-convert: command not found (install with: sudo apt install libheif-examples)" >&2
    return 1
  fi

  if [ $# -eq 0 ]; then
    echo "Usage: heic2jpg <files...>" >&2
    return 1
  fi

  local input output
  for input in "$@"; do
    case "${input,,}" in
      *.heic|*.heif)
        output="${input%.*}.jpg"
        heif-convert "$input" "$output" && echo "Converted: $input -> $output"
        ;;
      *)
        echo "Skipping (not HEIC/HEIF): $input" >&2
        ;;
    esac
  done
}