# Role-specific shell aliases generated by chezmoi.
{{ if eq .role "server" }}
# Follow docker container logs.
alias dockerlogs='docker logs -f'
# List running containers with name, status, and ports.
alias dps='docker ps --format "table {{`{{.Names}}`}}\t{{`{{.Status}}`}}\t{{`{{.Ports}}`}}"'
# Follow systemd journal logs for a unit.
alias journalf='journalctl -fu'
{{ end }}

{{ if or (eq .role "server") (eq .role "vm") }}
# Show listening TCP/UDP ports and owning processes.
alias ports='ss -tulpn'
# Show Tailscale node status.
alias tailscale-status='tailscale status'
{{ end }}

{{ if or (eq .role "devops") (eq .role "local") (eq .role "remote") }}
# Follow docker container logs.
alias dockerlogs='docker logs -f'
# List running containers with name, status, and ports.
alias dps='docker ps --format "table {{`{{.Names}}`}}\t{{`{{.Status}}`}}\t{{`{{.Ports}}`}}"'
# Shorthand for docker compose.
alias dcom='docker compose'
# Shorthand for kubectl.
alias k='kubectl'
# Switch the active kubectl context.
alias kctx='kubectl config use-context'
# List configured kubectl contexts.
alias kctxs='kubectl config get-contexts'
# List Helm releases.
alias helm-ls='helm list'
# Show listening TCP/UDP ports and owning processes.
alias ports='ss -tulpn'
# Show Tailscale node status.
alias tailscale-status='tailscale status'
{{ end }}
