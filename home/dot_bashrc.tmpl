# ~/.bashrc: executed by bash(1) for non-login shells.

# If not running interactively, don't do anything.
case $- in
    *i*) ;;
      *) return;;
esac

DF_DIR="${HOME}/.dotfiles"

# Compiled aliases, functions, fragments, role-aliases, and help (manual/aliases).
export DOTFILES_BOOTSTRAP="bashrc"
[ -r "${DF_DIR}/compiled/shell" ] && . "${DF_DIR}/compiled/shell"

# Prompt and shell tool init (mise, starship, fzf).
{{ template "source-bootstrap.tmpl" dict "bootstrap" .bootstrap "role" .role "shell" "bash" }}

# Host-specific bootstrap (untracked).
[ -r "${HOME}/.config/dotfiles/host-bootstrap" ] && . "${HOME}/.config/dotfiles/host-bootstrap"

# Alias definitions from ~/.bash_aliases.
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# Enable programmable completion.
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# Machine-local, untracked overrides.
[ -r ~/.bashrc.local ] && . ~/.bashrc.local

# Build PATH from chezmoi data.
{{ template "setup-path.tmpl" dict "paths" .paths }}

# Late shell integrations — must be at the very end.
{{ template "source-late-init.tmpl" dict "bootstrap" .bootstrap "shell" "bash" }}
