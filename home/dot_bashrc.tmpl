# ~/.bashrc: executed by bash(1) for non-login shells.

# If not running interactively, don't do anything.
case $- in
    *i*) ;;
      *) return;;
esac

DF_DIR="${HOME}/.dotfiles"

# Load common shell-agnostic helpers (shared across all roles and shells).
[ -r "${DF_DIR}/common/aliases" ] && . "${DF_DIR}/common/aliases"
[ -r "${DF_DIR}/common/functions" ] && . "${DF_DIR}/common/functions"
[ -r "${DF_DIR}/common/prompt" ] && . "${DF_DIR}/common/prompt"

# Load bash-specific helpers.
[ -r "${DF_DIR}/bash/init" ] && . "${DF_DIR}/bash/init"

# Load role-specific bash helpers.
{{- if eq .role "laptop" }}
[ -r "${DF_DIR}/laptop/bash/ssh" ] && . "${DF_DIR}/laptop/bash/ssh"
[ -r "${DF_DIR}/laptop/bash/server" ] && . "${DF_DIR}/laptop/bash/server"
{{- end }}
{{- if eq .role "server" }}
# Server-specific bash helpers
{{- end }}
{{- if eq .role "vm" }}
# VM-specific bash helpers
{{- end }}

# Load optional fragments based on configuration.
{{ template "load-fragments.tmpl" . }}

# Role-specific aliases generated by chezmoi.
[ -r "${HOME}/.config/dotfiles/role-aliases" ] && . "${HOME}/.config/dotfiles/role-aliases"

# Host-specific bootstrap (untracked).
[ -r "${HOME}/.config/dotfiles/host-bootstrap" ] && . "${HOME}/.config/dotfiles/host-bootstrap"

# Alias definitions from ~/.bash_aliases.
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# Enable programmable completion.
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# Machine-local, untracked overrides.
[ -r ~/.bashrc.local ] && . ~/.bashrc.local

# Ensure user-local bin is on PATH.
export PATH="$HOME/.local/bin:$PATH"
