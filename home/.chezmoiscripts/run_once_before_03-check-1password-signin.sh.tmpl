#!/bin/bash
# Verify 1Password CLI authentication before scripts that read secrets.
set -euo pipefail

{{- if not .coolify_cli }}
echo "coolify_cli not enabled on {{ .hostname }}; skipping 1Password check."
exit 0
{{- end }}

if ! command -v op >/dev/null 2>&1; then
  echo "1Password CLI (op) not found." >&2
  echo "Install: https://developer.1password.com/docs/cli/get-started/" >&2
  exit 1
fi

if ! op whoami >/dev/null 2>&1; then
  echo "1Password is not authenticated." >&2
  echo "Options:" >&2
  echo "  - Set OP_SERVICE_ACCOUNT_TOKEN (devcontainer / headless)" >&2
  echo "  - Enable 1Password desktop app CLI integration (laptop)" >&2
  echo "  - Run: op signin" >&2
  exit 1
fi

echo "1Password authenticated: $(op whoami 2>/dev/null | head -1)"
