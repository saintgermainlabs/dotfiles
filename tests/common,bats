#!/usr/bin/env bats

@test "[common] configuration files exist" {
    files_exists=(
        "${HOME}/.zshrc"
        "${HOME}/.config/starship.toml"
        "${HOME}/.config/nvim/init.lua"
        # ...
    )

    for file in "${files_exists[@]}"; do
        echo "Checking for existence of ${file}"
        [ -f "${file}" ]
    done
}

@test "[common] verify git configuration" {
    run git config --list
    [ "$status" -eq 0 ]
}
