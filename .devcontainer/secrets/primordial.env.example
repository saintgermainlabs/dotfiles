# Primordial environment — the first .env for all Linux-management devcontainers.
# Copy to primordial.env, fill in values, encrypt, and commit primordial.env.age.
#
#   cp .devcontainer/secrets/primordial.env.example .devcontainer/secrets/primordial.env
#   $EDITOR .devcontainer/secrets/primordial.env
#   .devcontainer/scripts/encrypt-primordial-env.sh
#
# Plaintext primordial.env is gitignored. primordial.env.age is baked into the
# primordial image at build time (ciphertext only) and decrypted at bootstrap.

export OP_SERVICE_ACCOUNT_TOKEN=""
export TAILSCALE_AUTHKEY=""
export COOLIFY_API_TOKEN=""
export COOLIFY_URL=""
export COOLIFY_DOCKER_HOST=""
export DOZZLE_HOST=""
export DOZZLE_PORT=""
export DOZZLE_USER=""
export DOZZLE_PASS=""
export ANTHROPIC_API_KEY=""
export GEMINI_API_KEY=""
