# Local devcontainer — 1Password app integration (no service account token needed).
#
# Prerequisites on the HOST (laptop):
#   1. 1Password desktop app installed and unlocked
#   2. Settings → Developer → "Integrate with 1Password CLI" enabled
#   3. bash .devcontainer/scripts/check-1password-app.sh succeeds (do not use sudo)
#
# Verify before rebuild:
#   bash .devcontainer/scripts/check-1password-app.sh
#
# Optional: resolve Tailscale / Dozzle refs from 1Password on the host at start
# TAILSCALE_AUTHKEY_REF=op://SG-Labs/Tailscale/devcontainer auth key

# ── Age key (used by host-side load-op-env if resolving refs) ───────────
OP_AGE_KEY_REF="op://Security Keys/chezmoi age key/key.txt"

# ── Coolify / Dozzle (optional host-side resolution) ────────────────────
COOLIFY_TOKEN_REF="op://SG-Labs/Coolify API/token"
DOZZLE_HOST_REF="op://SG-Labs/Dozzle/hostname"
DOZZLE_PORT_REF="op://SG-Labs/Dozzle/port"
DOZZLE_USER_REF="op://SG-Labs/Dozzle/username"
DOZZLE_PASS_REF="op://SG-Labs/Dozzle/password"

# ── Remote Docker (local devcontainer profile) ───────────────────────────
# COOLIFY_DOCKER_HOST=root@ubuntu-24.tiger-bushmaster.ts.net
