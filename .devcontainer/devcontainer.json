{
  "name": "Dotfiles Devcontainer",
  "remoteUser": "vscode",
  "initializeCommand": "bash .devcontainer/scripts/resolve-profile.sh && bash .devcontainer/scripts/load-op-env.sh",
  "build": {
    "dockerfile": "docker/Dockerfile",
    "context": ".",
    "target": "dotfiles"
  },
  "runArgs": [
    "--device=/dev/net/tun",
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--env-file",
    "${localWorkspaceFolder}/.devcontainer/.profile.runtime",
    "--env-file",
    "${localWorkspaceFolder}/.devcontainer/.env.runtime"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,readonly,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.1password,target=/home/vscode/.1password,type=bind,consistency=cached",
    "source=devcontainer-primordial-state,target=/var/lib/primordial,type=volume",
    "source=devcontainer-tailscale-state,target=/var/lib/tailscale,type=volume"
  ],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "dockerDashComposeVersion": "v2"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml",
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
