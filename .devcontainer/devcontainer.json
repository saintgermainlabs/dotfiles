{
  "name": "Dotfiles Devcontainer (Local)",
  "extends": "./devcontainer.base.json",
  "build": {
    "dockerfile": "docker/Dockerfile",
    "context": ".",
    "target": "dotfiles"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:2": {},
    "ghcr.io/devcontainers/features/docker-cli:1": {
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    }
  },
  "mounts": [
    "source=devcontainer-tailscale-state,target=/var/lib/tailscale,type=volume"
  ],
  "remoteEnv": {
    "DOTFILES_ROLE": "local",
    "DOTFILES_HOSTNAME": "devops-local01",
    "OP_SERVICE_ACCOUNT_TOKEN": "${localEnv:OP_SERVICE_ACCOUNT_TOKEN}"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml",
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
